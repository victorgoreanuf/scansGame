# Fernet key for encrypting stored passwords (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
VEYRA_FERNET_KEY=

# Database URL (default: SQLite in project dir)
VEYRA_DATABASE_URL=sqlite+aiosqlite:///./veyra.db

# Server
VEYRA_HOST=127.0.0.1
VEYRA_PORT=5678
